---
import { Image } from 'astro:assets';
import imgReference from '../../public/images/photo.jpg';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="TJ Nicolaides"
  description="Personal site for TJ Nicolaides, an Engineering Manager at Airbnb based in Ardmore, Pennsylvania."
>
  <main>
    <div class="tag">@tjnicolaides</div>

    <div class="photo-wrap">
      <Image src={imgReference} alt="TJ Nicolaides and the Phillie Phanatic" loading="eager" />
    </div>

    <h1>TJ Nicolaides</h1>
    <p class="role">Engineering Manager · Airbnb · Ardmore, PA</p>

    <div class="bio">
      <p>
        Built <strong>Airbnb-Friendly Apartments</strong> — renters hosting part-time, now with 1,300+ 
        buildings across four countries. People-first engineering leader helping collaborative, 
        creative teams navigate a rapidly transforming field. 
        <a href="https://youtu.be/DMOGXXs-kpY?si=GBbLIO7sx2Qx_Ndv" target="_blank" rel="noopener">Everybody hits.</a>
      </p>
    </div>

    <nav aria-label="Social links">
      <a href="https://www.linkedin.com/in/tnicolaides/" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        LinkedIn
      </a>
      <a href="https://github.com/tjnicolaides" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        GitHub
      </a>
      <a href="https://bsky.app/profile/tjnicolaides.bsky.social" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" class="icon-bluesky" aria-hidden="true">
          <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"></path>
        </svg>
        Bluesky
